import numpy as np
import pandas as pd
from sklearn.model_selection import train_test_split
from sklearn.preprocessing import StandardScaler
from sklearn.neighbors import KNeighborsRegressor
from sklearn.metrics import mean_squared_error


data = {
    'Height': [170, 160, 180, 175, 155, 190, 165, 185],
    'Weight': [80, 75, 70, 110, 90, 85, 60, 120],
    'ObesityScore': [40, 50, 20, 80, 70, 30, 15, 90] # Target to predict
}
df = pd.DataFrame(data)

# 2. Features and Target
X = df[['Height', 'Weight']]
y = df['ObesityScore']

# 3. Split data
X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.25, random_state=42)

# 4. Feature Scaling (Crucial for KNN)
scaler = StandardScaler()
X_train_scaled = scaler.fit_transform(X_train)
X_test_scaled = scaler.transform(X_test)

# 5. KNN Regression Model
knn_reg = KNeighborsRegressor(n_neighbors=3)
knn_reg.fit(X_train_scaled, y_train)

# 6. Predict and Evaluate
predictions = knn_reg.predict(X_test_scaled)
print("Predicted Scores:", predictions)
print("MSE:", mean_squared_error(y_test, predictions))

# 7. Convert Regression to "Obese or Not" (e.g., threshold > 50)
threshold = 50
binary_prediction = ["Obese" if p > threshold else "Not Obese" for p in predictions]
print("Classification:", binary_prediction)

